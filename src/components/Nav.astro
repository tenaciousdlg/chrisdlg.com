---
const links = [
  { href: '/',         label: 'Home'        },
  { href: '/resume',   label: 'Resume'      },
  { href: '/projects', label: 'Projects'    },
  { href: '/blog',     label: 'Field Notes' },
];

const current = Astro.url.pathname;
---

<header>
  <nav class="container">
    <a href="/" class="brand" aria-label="Home">
      Chris De La Garza
    </a>
    <ul role="list">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={['nav-link', { active: current === href || (href !== '/' && current.startsWith(href)) }]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<style>
  header {
    border-bottom: 1px solid var(--border-gold);
    background: rgba(11, 10, 18, 0.96);
    backdrop-filter: blur(6px);
    position: sticky;
    top: 0;
    z-index: 100;
    padding: 0.9rem 0;
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .brand {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--gold-bright);
    text-shadow: var(--glow);
    text-decoration: none;
    letter-spacing: 0.12em;
  }
  .brand:hover { color: var(--gold-bright); text-shadow: var(--glow-strong); }

  ul {
    display: flex;
    list-style: none;
    gap: 0.15rem;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-dim);
    padding: 0.25rem 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: color 0.2s, text-shadow 0.2s;
    position: relative;
    text-decoration: none;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0.65rem;
    right: 0.65rem;
    height: 1px;
    background: var(--gold);
    transform: scaleX(0);
    transition: transform 0.2s;
    transform-origin: center;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--gold-bright);
    text-shadow: var(--glow);
    text-decoration: none;
  }

  .nav-link.active::after,
  .nav-link:hover::after {
    transform: scaleX(1);
  }
</style>
