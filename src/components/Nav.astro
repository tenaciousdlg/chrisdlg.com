---
const links = [
  { href: '/',         label: 'HOME'      },
  { href: '/resume',   label: 'RESUME'    },
  { href: '/projects', label: 'PROJECTS'  },
  { href: '/blog',     label: 'BLOG'      },
  { href: '/doodles',  label: 'SKETCHBOOK'},
];

const current = Astro.url.pathname;
---

<header>
  <nav class="container">
    <a href="/" class="brand" aria-label="Home">
      <span class="brand-prompt">❯</span> chrisdlg<span class="brand-cursor"></span>
    </a>
    <div class="nav-right">
      <ul role="list">
        {links.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class:list={['nav-link', { active: current === href || (href !== '/' && current.startsWith(href)) }]}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
      <div class="social-links">
        <a href="https://github.com/tenaciousdlg" target="_blank" rel="noopener" class="social-link" aria-label="GitHub">GH</a>
        <a href="https://linkedin.com/in/cdlg" target="_blank" rel="noopener" class="social-link" aria-label="LinkedIn">LI</a>
      </div>
    </div>
  </nav>
</header>

<style>
  header {
    border-bottom: 1px solid var(--border-bright);
    background: var(--bg);
    position: sticky;
    top: 0;
    z-index: 100;
    padding: 0.75rem 0;
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .social-links {
    display: flex;
    gap: 0.25rem;
    border-left: 1px solid var(--border-bright);
    padding-left: 0.75rem;
  }

  .social-link {
    font-family: var(--font-pixel);
    font-size: 0.9rem;
    color: var(--text-dim);
    padding: 0.2rem 0.4rem;
    letter-spacing: 0.06em;
    transition: color 0.15s, text-shadow 0.15s;
    text-decoration: none;
  }
  .social-link:hover {
    color: var(--amber-bright);
    text-shadow: var(--glow);
    text-decoration: none;
  }

  .brand {
    font-family: var(--font-pixel);
    font-size: 1.4rem;
    color: var(--amber-bright);
    text-shadow: var(--glow);
    text-decoration: none;
  }
  .brand:hover { color: var(--amber-bright); text-shadow: var(--glow-strong); }

  .brand-prompt { color: var(--teal); }

  .brand-cursor {
    display: inline-block;
    width: 0.5em;
    height: 0.9em;
    background: var(--amber-bright);
    vertical-align: middle;
    margin-left: 2px;
    animation: blink 1s step-end infinite;
  }

  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }

  ul {
    display: flex;
    list-style: none;
    gap: 0.25rem;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    font-family: var(--font-pixel);
    font-size: 1rem;
    color: var(--text-dim);
    padding: 0.2rem 0.5rem;
    letter-spacing: 0.08em;
    transition: color 0.15s, text-shadow 0.15s;
    text-decoration: none;
  }
  .nav-link:hover,
  .nav-link.active {
    color: var(--amber-bright);
    text-shadow: var(--glow);
    text-decoration: none;
  }
  .nav-link.active {
    border-bottom: 1px solid var(--teal);
  }
</style>
