---
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = [
  {
    name: 'Infrastructure Identity for Platform Engineers',
    url: 'https://university.platformengineering.org/infrastructure-identity-for-platform-engineers',
    status: 'ACTIVE',
    stack: ['teleport', 'zero-trust', 'kubernetes', 'terraform'],
    description:
      'Free on-demand course (2 hrs) covering the shift from static credentials to cryptographic, short-lived identity for humans, machines, workloads, and AI agents. Produced with Platform Engineering University.',
    linkText: 'enroll free',
  },
  {
    name: 'The Joy of Terraforming',
    url: 'https://cloudflare.tv/event/5ZnyReaA',
    status: 'ARCHIVE',
    stack: ['terraform', 'cloudflare', 'zero-trust'],
    description:
      '30-minute Cloudflare TV segment walking through an initial Cloudflare deployment with Terraform — zones, DNS, Tunnels, and Access policies. Aired May 26, 2021.',
    linkText: 'watch on cloudflare.tv',
  },
  {
    name: 'teleport_terraform',
    url: 'https://github.com/tenaciousdlg/teleport_terraform',
    status: 'ACTIVE',
    stack: ['terraform', 'teleport'],
    description:
      'Collection of Teleport Terraform examples and patterns. Superseded by rev-tech at https://github.com/gravitational/rev-tech/tree/main/templates/teleport-terraform but kept for reference.',
  },
  {
    name: 'cloudflare_terraform',
    url: 'https://github.com/tenaciousdlg/cloudflare_terraform',
    status: 'ARCHIVE',
    stack: ['terraform', 'cloudflare'],
    description:
      'Earlier collection of Cloudflare Terraform examples and patterns.',
  },
  {
    name: 'app-demo-panel',
    url: 'https://github.com/tenaciousdlg/app-demo-panel',
    status: 'ACTIVE',
    stack: ['python', 'flask', 'teleport', 'jwt'],
    description:
      'Flask application that demonstrates Teleport application access. Decodes the Teleport-Jwt-Assertion header and renders the authenticated user\'s identity, roles, and traits in a clean UI. Useful for SE demos showing what downstream apps can consume from Teleport.',
  },
];
---

<BaseLayout title="Projects" description="Open source projects and infrastructure tools built by Chris De La Garza.">
  <h1 class="page-title">// QUEST LOG</h1>
  <p class="dim" style="margin-bottom:2rem;">Open source projects, demo infrastructure, and things I've shipped.</p>

  <ul class="project-list" role="list">
    {projects.map((p) => (
      <li class="project-card box">
        <div class="card-header">
          <a href={p.url} target="_blank" rel="noopener" class="project-name">{p.name}</a>
          <span class={`status-badge ${p.status === 'ACTIVE' ? 'active' : 'archive'}`}>{p.status}</span>
        </div>
        <div class="tags" style="margin:0.5rem 0;">
          {p.stack.map((t) => <span class="tag">{t}</span>)}
        </div>
        <p class="project-desc">{p.description}</p>
        <a href={p.url} target="_blank" rel="noopener" class="card-link">{p.linkText ?? 'view on github'} &gt;</a>
      </li>
    ))}
  </ul>
</BaseLayout>

<style>
  .page-title { font-size: 2rem; margin-bottom: 0.5rem; }
  .project-list { list-style: none; padding: 0; display: grid; gap: 1.25rem; }

  .project-card { padding: 1.25rem !important; }
  .card-header  { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 0.2rem; }
  .project-name { font-family: var(--font-pixel); font-size: 1.2rem; color: var(--green-bright); letter-spacing: 0.05em; }
  .project-name:hover { text-shadow: var(--glow-strong); }

  .status-badge {
    font-family: var(--font-pixel);
    font-size: 0.75rem;
    padding: 0.1em 0.5em;
    letter-spacing: 0.1em;
    border: 1px solid;
  }
  .status-badge.active  { color: var(--green-bright); border-color: var(--green-bright); }
  .status-badge.archive { color: var(--green-dim);    border-color: var(--green-dim); }

  .project-desc { color: var(--white); font-size: 0.9rem; margin: 0.4rem 0 0.6rem; line-height: 1.6; }
  .card-link    { font-size: 0.85rem; }
</style>
