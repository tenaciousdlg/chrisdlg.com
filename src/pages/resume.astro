---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Resume" description="Chris De La Garza — Senior Solutions Engineer. Infrastructure, security, cloud, and pre-sales.">
  <h1 class="glitch page-title">// CHARACTER SHEET</h1>

  <!-- Download block -->
  <div class="box download-box" data-title="SAVE FILE">
    <p class="dim" style="margin-bottom:1rem; font-size:0.9rem;">Download a copy of my resume:</p>
    <div class="download-links">
      <a href="/Chris_De_La_Garza_Resume_1Page.pdf" download class="dl-btn primary">
        <span class="dl-icon">↓</span>
        <span class="dl-label">1-Page <span class="dim">(recommended)</span></span>
      </a>
      <a href="/Chris_De_La_Garza_Resume_Light.pdf" download class="dl-btn">
        <span class="dl-icon">↓</span>
        <span class="dl-label">Full Resume <span class="dim">· light</span></span>
      </a>
      <a href="/Chris_De_La_Garza_Resume.pdf" download class="dl-btn">
        <span class="dl-icon">↓</span>
        <span class="dl-label">Full Resume <span class="dim">· dark</span></span>
      </a>
    </div>
  </div>

  <!-- Identity block -->
  <div class="box" data-title="IDENTITY">
    <div class="identity-grid">
      <div>
        <div class="field"><span class="label">NAME</span><span class="value">Chris De La Garza</span></div>
        <div class="field"><span class="label">CLASS</span><span class="value amber">Senior Solutions Engineer</span></div>
        <div class="field"><span class="label">COMPANY</span><span class="value">Teleport</span></div>
        <div class="field"><span class="label">LOCATION</span><span class="value">Austin, TX / Denver, CO</span></div>
      </div>
      <div>
        <div class="field"><span class="label">CONTACT</span><a href="mailto:hi@chrisdlg.com">hi@chrisdlg.com</a></div>
        <div class="field"><span class="label">LINKEDIN</span><a href="https://linkedin.com/in/cdlg" target="_blank" rel="noopener">linkedin.com/in/cdlg</a></div>
        <div class="field"><span class="label">GITHUB</span><a href="https://github.com/tenaciousdlg" target="_blank" rel="noopener">tenaciousdlg</a></div>
        <div class="field"><span class="label">HONORS</span><span class="value amber">SE of the Year · FY25</span></div>
        <div class="field"><span class="label"></span><span class="value amber">146.5% Quota Attainment · FY26</span></div>
      </div>
    </div>
    <div class="summary">
      <p>
        Infrastructure Engineer turned Solutions Engineer with a decade of building, breaking, and securing systems
        across bare metal, cloud, and Kubernetes. Known for building demo and enablement systems that outlast the
        engagement. Specializes in translating complex technical architecture
        into clear business outcomes during pre-sales engagements.
      </p>
    </div>
  </div>

  <!-- Proficiency tiers -->
  <div class="box" data-title="PROFICIENCY LEVELS">
    <div class="tier-grid">
      <div class="tier">
        <h3 class="tier-label expert">EXPERT</h3>
        <ul>
          <li>Pre-Sales / Solutions Engineering</li>
          <li>Linux Systems Administration</li>
          <li>Bash / Shell Scripting</li>
          <li>Infrastructure as Code (Terraform)</li>
        </ul>
      </div>
      <div class="tier">
        <h3 class="tier-label proficient">PROFICIENT</h3>
        <ul>
          <li>Network Security / Zero Trust</li>
          <li>Kubernetes / Container Orchestration</li>
          <li>Cloud Platforms (AWS / GCP / Azure)</li>
          <li>Technical Enablement &amp; Training</li>
        </ul>
      </div>
      <div class="tier">
        <h3 class="tier-label familiar">FAMILIAR</h3>
        <ul>
          <li>Python</li>
          <li>Go</li>
          <li>JavaScript</li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Tech stack -->
  <div class="box" data-title="TECH STACK">
    <div class="stack-grid">
      <div class="stack-group">
        <h3>Infrastructure</h3>
        <ul>
          <li>Terraform / OpenTofu</li>
          <li>Ansible</li>
          <li>Docker / Docker Compose</li>
          <li>Kubernetes (EKS, GKE, AKS)</li>
          <li>Cloudflare Tunnels</li>
        </ul>
      </div>
      <div class="stack-group">
        <h3>Cloud &amp; Networking</h3>
        <ul>
          <li>AWS (EC2, EKS, IAM, VPC, S3)</li>
          <li>GCP / Azure</li>
          <li>Cloudflare (CDN, WAF, Workers, Zero Trust)</li>
          <li>DNS, SSL/TLS, BGP basics</li>
        </ul>
      </div>
      <div class="stack-group">
        <h3>Security &amp; Identity</h3>
        <ul>
          <li>Teleport (PAM / Zero Trust)</li>
          <li>Okta (SAML, SCIM, SSO)</li>
          <li>mTLS, PKI, certificate management</li>
          <li>RBAC / access request workflows</li>
        </ul>
      </div>
      <div class="stack-group">
        <h3>Databases &amp; Apps</h3>
        <ul>
          <li>PostgreSQL, MySQL / MariaDB</li>
          <li>MongoDB, Cassandra</li>
          <li>NGINX, Apache</li>
          <li>Python (Flask), Bash</li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Quest Log -->
  <div class="box" data-title="EXPERIENCE">

    <div class="quest">
      <div class="quest-header">
        <span class="quest-company amber">Teleport</span>
        <span class="quest-role">Senior Solutions Engineer</span>
        <span class="quest-date dim">Sep 2023 – Present</span>
      </div>
      <ul>
        <li>Enterprise pre-sales across AWS, GCP, Azure, and on-prem — closed the <strong class="amber">largest deal in company history</strong></li>
        <li>Named <strong class="amber">Solutions Engineer of the Year FY25</strong>; exceeded quota every year at Teleport including <strong class="amber">146.5% attainment in FY26</strong></li>
        <li>Designed and authored the <a href="https://github.com/tenaciousdlg/rev-tech">teleport-terraform reference architecture</a> — a full IaC template (EKS control plane, RBAC, SCIM, plugins, database access) adopted as the team's standard demo foundation</li>
        <li>Rebuilt and championed codifying conference demo infrastructure into documented, repeatable playbooks across the SE org — reducing setup time and improving demo consistency at field events</li>
        <li>Designed a 3-tier RBAC model integrating Okta group membership → Teleport Access Lists via SCIM, eliminating manual user management</li>
        <li>Deliver product demonstrations covering SSH, RDP, Kubernetes, database access, and machine identity across complex customer environments</li>
        <li>Mentor and support junior SEs on technical architecture and demo delivery</li>
      </ul>
    </div>

    <div class="quest">
      <div class="quest-header">
        <span class="quest-company amber">Cloudflare</span>
        <span class="quest-role">Solutions Engineer – Strategic Accounts</span>
        <span class="quest-date dim">Feb 2022 – Sep 2023</span>
      </div>
      <ul>
        <li>Technical lead for Central and West Field/Strategic teams supporting Fortune 500 accounts</li>
        <li>North America SME for API Shield, Cloudflare Tunnel, Docker, and Terraform</li>
        <li>Built new-hire training program that cut SE onboarding from <strong>9 months to 90 days</strong></li>
        <li>Created Terraform examples and reusable templates for Cloudflare Tunnels deployment at scale (Terraform + Ansible + Docker)</li>
        <li>Assisted with team interviews and organizational structure for Strategic SE team buildout</li>
      </ul>
    </div>

    <div class="quest">
      <div class="quest-header">
        <span class="quest-company amber">NGINX, Inc.</span>
        <span class="quest-role">Solutions Engineer III</span>
        <span class="quest-date dim">Jun 2021 – Dec 2021</span>
      </div>
      <ul>
        <li>Collaborated directly with core engineering and product on feature direction for financial and public sector clients</li>
        <li>Designed hybrid bare-metal-to-cloud solutions involving Kubernetes microservices architecture</li>
        <li>Co-facilitated NGINX Sprint API management workshop including development, testing, and delivery</li>
      </ul>
    </div>

    <div class="quest">
      <div class="quest-header">
        <span class="quest-company amber">Cloudflare, Inc.</span>
        <span class="quest-role">Solutions Engineer</span>
        <span class="quest-date dim">Apr 2019 – May 2021</span>
      </div>
      <ul>
        <li>Technical sales expert across the full Cloudflare product surface: CDN, DNS, WAF, Bot Management, Workers, Zero Trust</li>
        <li>Founding member of Austin Mid-Market SE team; helped establish team SOPs and cultural foundation</li>
        <li>Technical lead supporting up to 15 Account Executives</li>
        <li>Developed reproducible demos via Terraform/shell scripting/Docker that became standardized tooling for the SE org</li>
        <li>Led SE booth and back-end demo infrastructure at Cloudflare Connect Conference 2019</li>
      </ul>
    </div>

    <div class="quest">
      <div class="quest-header">
        <span class="quest-company amber">Rackspace</span>
        <span class="quest-role">Linux System Engineer II → I → Support</span>
        <span class="quest-date dim">Oct 2015 – Apr 2019</span>
      </div>
      <ul>
        <li>Managed Linux systems (RHEL/Debian) for dedicated and cloud customers: Apache, MySQL, PHP, DNS, SSH</li>
        <li>Progressed from L1 support through Linux Sys Engineer II in ~3.5 years</li>
        <li>Implemented automation to reduce repetitive escalation work; mentored junior technicians</li>
        <li>Supported environments ranging from single LAMP stacks to large enterprise AWS/Azure/VMware deployments</li>
      </ul>
    </div>
  </div>

  <!-- Education & Certs -->
  <div class="box" data-title="EDUCATION &amp; CERTIFICATIONS">
    <div class="lore-grid">
      <div>
        <h3>Education</h3>
        <p><strong class="bright">Texas A&amp;M University – Corpus Christi</strong></p>
        <p>B.B.A., Bachelor of Business Administration &nbsp;· 2011–2014</p>
        <p class="dim">Dean's List: Spring 2013, Spring 2014</p>
      </div>
      <div>
        <h3>Certifications</h3>
        <ul>
          <li>Great Demo! Practitioner</li>
        </ul>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .page-title { font-size: 2rem; margin-bottom: 1.5rem; }

  .download-box { margin-bottom: 1.5rem; }
  .download-links { display: flex; flex-wrap: wrap; gap: 0.6rem; }
  .dl-btn {
    display: inline-flex; align-items: center; gap: 0.5rem;
    border: 1px solid var(--border-bright);
    padding: 0.4rem 0.9rem;
    font-family: var(--font-pixel);
    font-size: 0.95rem;
    color: var(--text-bright);
    transition: border-color 0.2s, color 0.2s, text-shadow 0.2s;
  }
  .dl-btn:hover { border-color: var(--amber); color: var(--amber-bright); text-shadow: var(--glow); }
  .dl-btn.primary { border-color: var(--amber); color: var(--amber-bright); }
  .dl-btn.primary:hover { text-shadow: var(--glow-strong); }
  .dl-icon { font-size: 1.1rem; }

  .identity-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem 2rem;
    margin-bottom: 1rem;
  }
  .field { display: flex; gap: 0.75rem; margin-bottom: 0.25rem; flex-wrap: wrap; }
  .label { min-width: 90px; color: var(--green-dim); font-size: 0.85rem; flex-shrink: 0; }
  .value { color: var(--white); }
  .summary { border-top: 1px solid var(--border); padding-top: 1rem; color: var(--white); }

  .tier-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    width: 100%;
  }
  .tier {
    min-width: 0;
  }
  .tier-label { font-size: 0.8rem; font-family: var(--font-pixel); letter-spacing: 0.1em; margin-bottom: 0.75rem; }
  .tier-label.expert { color: var(--green-bright); }
  .tier-label.proficient { color: var(--amber); }
  .tier-label.familiar { color: var(--white); }
  .tier ul { list-style: none !important; padding: 0; margin: 0; }
  .tier li { padding-left: 1.2rem; position: relative; margin-bottom: 0.3rem; color: var(--white); font-size: 0.9rem; list-style: none; }
  .tier li::before { content: '> '; color: var(--green-dim); position: absolute; left: 0; }

  .stack-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
  }
  .stack-group h3 { font-size: 1rem; margin-bottom: 0.5rem; color: var(--amber); font-family: var(--font-pixel); }
  .stack-group ul { list-style: none; padding: 0; }
  .stack-group li::before { content: '> '; color: var(--green-dim); }

  .quest { margin-bottom: 1.75rem; padding-bottom: 1.75rem; border-bottom: 1px solid var(--bg-3); }
  .quest:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
  .quest-header { display: flex; flex-wrap: wrap; gap: 0.5rem 1rem; align-items: baseline; margin-bottom: 0.6rem; }
  .quest-company { font-family: var(--font-pixel); font-size: 1.1rem; letter-spacing: 0.06em; }
  .quest-role { color: var(--white); }
  .quest-date { font-size: 0.85rem; }
  .quest ul { list-style: none; padding: 0; }
  .quest li { padding-left: 1.2rem; position: relative; margin-bottom: 0.3rem; color: var(--green); }
  .quest li::before { content: '–'; position: absolute; left: 0; color: var(--green-dim); }

  .lore-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
  .lore-grid h3 { font-size: 1rem; font-family: var(--font-pixel); color: var(--amber); margin-bottom: 0.5rem; }

  @media (max-width: 640px) {
    .identity-grid, .lore-grid, .tier-grid { grid-template-columns: 1fr; }
  }
</style>