---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

const posts = (await getCollection('blog', ({ data }: CollectionEntry<'blog'>) => !data.draft))
  .sort((a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<BaseLayout title="Home">
  <section class="hero">
    <div class="title-card">
      <div class="tc-top">◈─────────────────────────◈</div>
      <div class="tc-name glitch">CHRIS DE LA GARZA</div>
      <div class="tc-role">SR. SOLUTIONS ENGINEER</div>
      <div class="tc-bot">◈─────────────────────────◈</div>
    </div>
    <div id="boot" class="boot-terminal" aria-live="polite"></div>
  </section>

  <section class="box" data-title="NAVIGATE">
    <div class="link-grid">
      <a href="/resume" class="quick-link">
        <span class="ql-icon">[ ♦ ]</span>
        <span class="ql-label">CHARACTER SHEET</span>
        <span class="ql-sub">resume &amp; skills</span>
      </a>
      <a href="/projects" class="quick-link">
        <span class="ql-icon">[ ◈ ]</span>
        <span class="ql-label">QUEST LOG</span>
        <span class="ql-sub">open source projects</span>
      </a>
      <a href="/blog" class="quick-link">
        <span class="ql-icon">[ ✦ ]</span>
        <span class="ql-label">FIELD NOTES</span>
        <span class="ql-sub">technical writing</span>
      </a>
    </div>
  </section>

  {posts.length > 0 && (
    <section>
      <h2 style="margin-bottom:1rem;">// RECENT FIELD NOTES</h2>
      <ul class="post-list" role="list">
        {posts.map((post: CollectionEntry<'blog'>) => (
          <li class="post-item">
            <span class="post-date dim">{post.data.date.toISOString().slice(0, 10)}</span>
            <span class="post-sep amber"> &gt; </span>
            <a href={`/blog/${post.id}`}>{post.data.title}</a>
            {post.data.tags.length > 0 && (
              <span class="tags">
                {post.data.tags.map((t: string) => <span class="tag">{t}</span>)}
              </span>
            )}
          </li>
        ))}
      </ul>
      <p style="margin-top:1rem;"><a href="/blog">view all posts &gt;</a></p>
    </section>
  )}
</BaseLayout>

<script>
  const lines = [
    '> ACCESSING PERSONNEL FILE...',
    '> SUBJECT......... De La Garza, Chris',
    '> DESIGNATION..... Sr. Solutions Engineer',
    '> CURRENT POST.... Teleport  |  Austin, TX',
    '> EXPERTISE....... Infrastructure · Security · Pre-Sales',
    '> COMMENDATION.... SE of the Year, FY25',
    '> STATUS.......... ACTIVE',
  ];

  const el = document.getElementById('boot');
  if (el) {
    let lineIdx = 0;
    let charIdx = 0;
    let output = '';

    function tick() {
      if (lineIdx >= lines.length) {
        el!.innerHTML = output + '<span class="cursor"></span>';
        return;
      }
      const line = lines[lineIdx]!;
      if (charIdx < line.length) {
        output += line[charIdx];
        el!.textContent = output;
        charIdx++;
        setTimeout(tick, charIdx === 1 && lineIdx > 0 ? 35 : 16);
      } else {
        output += '\n';
        charIdx = 0;
        lineIdx++;
        setTimeout(tick, lineIdx === lines.length ? 0 : 55);
      }
    }
    setTimeout(tick, 400);
  }
</script>

<style>
  .hero { margin-bottom: 2.5rem; }

  /* SNES-style title card */
  .title-card {
    font-family: var(--font-pixel);
    text-align: center;
    margin-bottom: 2rem;
    line-height: 1.4;
  }
  .tc-top, .tc-bot {
    color: var(--amber-dim);
    letter-spacing: 0.05em;
    font-size: 1.1rem;
  }
  .tc-name {
    font-size: clamp(2rem, 6vw, 3.5rem);
    color: var(--amber-bright);
    text-shadow: var(--glow-strong);
    letter-spacing: 0.12em;
    padding: 0.1em 0;
  }
  .tc-role {
    font-size: 1.1rem;
    color: var(--teal);
    letter-spacing: 0.18em;
    text-shadow: 0 0 8px rgba(42, 154, 136, 0.4);
    margin-bottom: 0.2em;
  }

  .boot-terminal {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--text);
    white-space: pre-line;
    min-height: 9em;
    border-left: 2px solid var(--border-bright);
    padding-left: 1rem;
    line-height: 1.85;
  }

  /* nav cards */
  .link-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
  }
  .quick-link {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 1rem;
    border: 1px solid var(--border);
    background: var(--bg);
    transition: border-color 0.2s, background 0.2s;
    text-decoration: none;
  }
  .quick-link:hover {
    border-color: var(--amber);
    background: var(--bg-3);
    text-decoration: none;
    box-shadow: inset 0 0 14px rgba(200, 144, 42, 0.06);
  }
  .ql-icon  { font-family: var(--font-pixel); font-size: 1.1rem; color: var(--teal); }
  .ql-label { font-family: var(--font-pixel); font-size: 1.05rem; color: var(--amber-bright); letter-spacing: 0.06em; }
  .ql-sub   { font-size: 0.8rem; color: var(--text-dim); }

  /* recent posts */
  .post-list  { list-style: none; padding: 0; margin: 0; }
  .post-item  { padding: 0.4rem 0; border-bottom: 1px solid var(--bg-3); display: flex; flex-wrap: wrap; align-items: baseline; gap: 0.4rem; }
  .post-date  { font-size: 0.85rem; }
  .post-sep   { font-family: var(--font-pixel); }
</style>
