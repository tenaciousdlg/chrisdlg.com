---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

const posts = (await getCollection('blog', ({ data }: CollectionEntry<'blog'>) => !data.draft))
  .sort((a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<BaseLayout title="Home">
  <section class="hero">
    <div class="hero-eyebrow">chrisdlg.com</div>
    <h1 class="hero-name glitch">Chris De La Garza</h1>
    <p class="hero-title">Senior Solutions Engineer &nbsp;·&nbsp; Austin, TX</p>
    <hr class="hero-rule" />
    <div id="boot" class="boot-terminal" aria-live="polite"></div>
  </section>

  <section class="quick-links box" data-title="EXPLORE">
    <div class="link-grid">
      <a href="/resume" class="quick-link">
        <span class="icon">♦</span>
        <span class="ql-label">Resume</span>
        <span class="ql-sub">character sheet &amp; skills</span>
      </a>
      <a href="/projects" class="quick-link">
        <span class="icon">◈</span>
        <span class="ql-label">Projects</span>
        <span class="ql-sub">open source &amp; infrastructure</span>
      </a>
      <a href="/blog" class="quick-link">
        <span class="icon">✦</span>
        <span class="ql-label">Field Notes</span>
        <span class="ql-sub">technical writing</span>
      </a>
    </div>
  </section>

  {posts.length > 0 && (
    <section>
      <h2 class="section-heading">Recent Field Notes</h2>
      <ul class="post-list" role="list">
        {posts.map((post: CollectionEntry<'blog'>) => (
          <li class="post-item">
            <time class="post-date dim" datetime={post.data.date.toISOString()}>
              {post.data.date.toISOString().slice(0, 10)}
            </time>
            <span class="post-sep"> — </span>
            <a href={`/blog/${post.id}`}>{post.data.title}</a>
            {post.data.tags.length > 0 && (
              <span class="tags">
                {post.data.tags.map((t: string) => <span class="tag">{t}</span>)}
              </span>
            )}
          </li>
        ))}
      </ul>
      <p style="margin-top:1.25rem;"><a href="/blog">All posts →</a></p>
    </section>
  )}
</BaseLayout>

<script>
  const lines = [
    'Initializing profile...',
    'Class ........... Senior Solutions Engineer',
    'Guild ........... Teleport',
    'Location ........ Austin, TX',
    'Specialization .. Infrastructure · Security · Pre-Sales',
    'Active quest .... Securing distributed infrastructure at scale',
    'Status .......... Online',
  ];

  const el = document.getElementById('boot');
  if (el) {
    let lineIdx = 0;
    let charIdx = 0;
    let output = '';

    function tick() {
      if (lineIdx >= lines.length) {
        el!.innerHTML = output + '<span class="cursor"></span>';
        return;
      }
      const line = lines[lineIdx]!;
      if (charIdx < line.length) {
        output += line[charIdx];
        el!.textContent = output;
        charIdx++;
        setTimeout(tick, charIdx === 1 && lineIdx > 0 ? 35 : 16);
      } else {
        output += '\n';
        charIdx = 0;
        lineIdx++;
        setTimeout(tick, lineIdx === lines.length ? 0 : 55);
      }
    }
    setTimeout(tick, 300);
  }
</script>

<style>
  /* ── Hero ──────────────────────────────── */
  .hero { margin-bottom: 3rem; padding-top: 1rem; }

  .hero-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-dim);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 0.6rem;
  }

  .hero-name {
    font-size: clamp(2rem, 5vw, 3.2rem);
    letter-spacing: 0.1em;
    margin-bottom: 0.4rem;
    font-weight: 700;
  }

  .hero-title {
    font-family: var(--font-mono);
    font-size: 0.92rem;
    color: var(--text);
    margin-bottom: 1.5rem;
    letter-spacing: 0.05em;
  }

  .hero-rule {
    border: none;
    border-top: 1px solid var(--border-gold);
    margin-bottom: 1.5rem;
    position: relative;
  }
  .hero-rule::after {
    content: '✦';
    position: absolute;
    top: -0.6em;
    left: 0;
    background: var(--bg);
    padding-right: 0.6em;
    color: var(--gold-dim);
    font-size: 0.75rem;
  }

  .boot-terminal {
    font-family: var(--font-mono);
    font-size: 0.88rem;
    color: var(--text);
    white-space: pre-line;
    min-height: 10em;
    border-left: 2px solid var(--border-gold);
    padding-left: 1.25rem;
    line-height: 1.9;
  }

  /* ── Nav cards ─────────────────────────── */
  .link-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
    gap: 1rem;
  }

  .quick-link {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1.1rem 1.25rem;
    border: 1px solid var(--border-gold);
    background: var(--bg);
    transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
    text-decoration: none;
  }
  .quick-link:hover {
    border-color: var(--gold);
    background: var(--bg-3);
    box-shadow: 0 0 16px rgba(201, 168, 76, 0.08);
    text-decoration: none;
  }

  .icon     { font-size: 1rem; color: var(--gold); margin-bottom: 0.1rem; }
  .ql-label { font-family: var(--font-heading); font-size: 0.95rem; color: var(--gold-bright); letter-spacing: 0.08em; font-weight: 600; }
  .ql-sub   { font-size: 0.78rem; color: var(--text-dim); }

  /* ── Recent posts ──────────────────────── */
  .section-heading { font-size: 1.1rem; margin-bottom: 1rem; letter-spacing: 0.12em; }
  .post-list  { list-style: none; padding: 0; margin: 0; }
  .post-item  { padding: 0.45rem 0; border-bottom: 1px solid var(--border); display: flex; flex-wrap: wrap; align-items: baseline; gap: 0.4rem; }
  .post-date  { font-size: 0.82rem; }
  .post-sep   { color: var(--gold-dim); }
</style>
