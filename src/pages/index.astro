---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

const posts = (await getCollection('blog', ({ data }: CollectionEntry<'blog'>) => !data.draft))
  .sort((a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<BaseLayout title="Home">
  <section class="hero">
    <div class="hero-inner">

      <!-- ── Pixel character card ────────────── -->
      <div class="char-card" id="char-card">
        <div class="portrait-frame">
          <img src="/avatar.png" alt="Pixel portrait of Chris De La Garza" width="192" height="192" />
          <div class="select-cursor" aria-hidden="true">►</div>
        </div>
        <div class="char-stats">
          <div class="char-name">DE LA GARZA</div>
          <div class="char-class">SR. SOLUTIONS ENG.</div>
          <div class="stat-row">
            <span class="stat-label">HP</span>
            <div class="stat-track"><div class="stat-fill" style="width:100%"></div></div>
          </div>
          <div class="stat-row">
            <span class="stat-label">EXP</span>
            <div class="stat-track"><div class="stat-fill exp" style="width:75%"></div></div>
          </div>
        </div>
        <div class="char-dialog" id="char-dialog" aria-live="polite">
          <span class="dialog-arrow">▶</span>
          <span id="dialog-text"></span><span class="cursor dialog-cursor-blink"></span>
        </div>
      </div>

      <!-- ── Title + boot terminal ───────────── -->
      <div class="hero-right">
        <div class="title-card">
          <div class="tc-top">◈─────────────────────────◈</div>
          <div class="tc-name glitch">CHRIS DE LA GARZA</div>
          <div class="tc-role">SR. SOLUTIONS ENGINEER</div>
          <div class="tc-bot">◈─────────────────────────◈</div>
        </div>
        <div id="boot" class="boot-terminal" aria-live="polite"></div>
      </div>

    </div>
  </section>

  <section class="box" data-title="NAVIGATE">
    <div class="link-grid">
      <a href="/resume" class="quick-link">
        <span class="ql-icon">[ ♦ ]</span>
        <span class="ql-label">CHARACTER SHEET</span>
        <span class="ql-sub">resume &amp; skills</span>
      </a>
      <a href="/projects" class="quick-link">
        <span class="ql-icon">[ ◈ ]</span>
        <span class="ql-label">QUEST LOG</span>
        <span class="ql-sub">open source projects</span>
      </a>
      <a href="/blog" class="quick-link">
        <span class="ql-icon">[ ✦ ]</span>
        <span class="ql-label">FIELD NOTES</span>
        <span class="ql-sub">technical writing</span>
      </a>
    </div>
  </section>

  {posts.length > 0 && (
    <section>
      <h2 style="margin-bottom:1rem;">// RECENT FIELD NOTES</h2>
      <ul class="post-list" role="list">
        {posts.map((post: CollectionEntry<'blog'>) => (
          <li class="post-item">
            <span class="post-date dim">{post.data.date.toISOString().slice(0, 10)}</span>
            <span class="post-sep amber"> &gt; </span>
            <a href={`/blog/${post.id}`}>{post.data.title}</a>
            {post.data.tags.length > 0 && (
              <span class="tags">
                {post.data.tags.map((t: string) => <span class="tag">{t}</span>)}
              </span>
            )}
          </li>
        ))}
      </ul>
      <p style="margin-top:1rem;"><a href="/blog">view all posts &gt;</a></p>
    </section>
  )}
</BaseLayout>

<script>
  /* ── Boot terminal ─────────────────────── */
  const lines = [
    '> ACCESSING PERSONNEL FILE...',
    '> SUBJECT......... De La Garza, Chris',
    '> DESIGNATION..... Sr. Solutions Engineer',
    '> CURRENT POST.... Teleport  |  Austin, TX',
    '> EXPERTISE....... Infrastructure · Security · Pre-Sales',
    '> COMMENDATION.... SE of the Year, FY25',
    '> STATUS.......... ACTIVE',
  ];

  const bootEl = document.getElementById('boot');
  if (bootEl) {
    let lineIdx = 0, charIdx = 0, output = '';
    function bootTick() {
      if (lineIdx >= lines.length) {
        bootEl!.innerHTML = output + '<span class="cursor"></span>';
        return;
      }
      const line = lines[lineIdx]!;
      if (charIdx < line.length) {
        output += line[charIdx]; bootEl!.textContent = output; charIdx++;
        setTimeout(bootTick, charIdx === 1 && lineIdx > 0 ? 35 : 16);
      } else {
        output += '\n'; charIdx = 0; lineIdx++;
        setTimeout(bootTick, lineIdx === lines.length ? 0 : 55);
      }
    }
    setTimeout(bootTick, 400);
  }

  /* ── Character card dialog on hover ───── */
  const card    = document.getElementById('char-card');
  const dialog  = document.getElementById('char-dialog');
  const dtEl    = document.getElementById('dialog-text');
  const message = 'PERSONNEL FILE ACCESSED.\nSEEK GRACE.';

  let typingTimer: ReturnType<typeof setTimeout> | null = null;
  let shown = false;

  function typeDialog() {
    if (!dtEl || !dialog) return;
    dialog.classList.add('visible');
    dtEl.textContent = '';
    let i = 0;
    function type() {
      if (i < message.length) {
        dtEl!.textContent += message[i++];
        typingTimer = setTimeout(type, 45);
      }
    }
    type();
  }

  function hideDialog() {
    if (!dialog || !dtEl) return;
    if (typingTimer) clearTimeout(typingTimer);
    dialog.classList.remove('visible');
    dtEl.textContent = '';
    shown = false;
  }

  if (card) {
    card.addEventListener('mouseenter', () => { if (!shown) { shown = true; typeDialog(); } });
    card.addEventListener('mouseleave', hideDialog);
    card.addEventListener('touchstart', () => { if (!shown) { shown = true; typeDialog(); } }, { passive: true });
  }
</script>

<style>
  /* ── Hero layout ───────────────────────── */
  .hero { margin-bottom: 2.5rem; }

  .hero-inner {
    display: flex;
    gap: 2.5rem;
    align-items: flex-start;
  }

  @media (max-width: 680px) {
    .hero-inner { flex-direction: column; align-items: center; }
    .hero-right  { width: 100%; }
  }

  /* ── Character card ────────────────────── */
  .char-card {
    flex-shrink: 0;
    width: 196px;
    cursor: default;
    user-select: none;
  }

  .portrait-frame {
    border: 2px solid var(--border-bright);
    background: #fff;
    position: relative;
    overflow: hidden;
    line-height: 0;
  }
  .portrait-frame img {
    width: 192px;
    height: 192px;
    display: block;
    image-rendering: pixelated;
  }

  /* Selection cursor — hidden until hover */
  .select-cursor {
    position: absolute;
    left: 4px;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--font-pixel);
    font-size: 1.4rem;
    color: var(--amber-bright);
    text-shadow: var(--glow);
    opacity: 0;
    transition: opacity 0.15s;
    animation: blink 0.7s step-end infinite;
  }
  @keyframes blink { 0%,100%{opacity:0} 50%{opacity:1} }

  .char-card:hover .select-cursor,
  .char-card:focus-within .select-cursor { opacity: 1; }

  .char-stats {
    border: 2px solid var(--border-bright);
    border-top: none;
    background: var(--bg-2);
    padding: 0.5rem 0.6rem 0.4rem;
  }

  .char-name {
    font-family: var(--font-pixel);
    font-size: 1rem;
    color: var(--amber-bright);
    text-shadow: var(--glow);
    letter-spacing: 0.08em;
    line-height: 1.3;
  }
  .char-class {
    font-family: var(--font-pixel);
    font-size: 0.75rem;
    color: var(--teal);
    letter-spacing: 0.06em;
    margin-bottom: 0.5rem;
  }

  .stat-row {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.25rem;
  }
  .stat-label {
    font-family: var(--font-pixel);
    font-size: 0.72rem;
    color: var(--text-dim);
    min-width: 2.2em;
  }
  .stat-track {
    flex: 1;
    height: 7px;
    background: var(--bg-3);
    border: 1px solid var(--border);
    overflow: hidden;
  }
  .stat-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--amber-dim), var(--amber-bright));
    box-shadow: 0 0 4px rgba(200, 144, 42, 0.5);
  }
  .stat-fill.exp {
    background: linear-gradient(90deg, var(--teal-dim), var(--teal));
  }

  /* RPG dialog box */
  .char-dialog {
    border: 2px solid var(--border-bright);
    border-top: none;
    background: var(--bg-3);
    padding: 0.5rem 0.6rem;
    font-family: var(--font-pixel);
    font-size: 0.82rem;
    color: var(--text-bright);
    white-space: pre-line;
    min-height: 3.2em;
    display: flex;
    gap: 0.3rem;
    align-items: flex-start;
    opacity: 0;
    transform: translateY(-4px);
    transition: opacity 0.2s, transform 0.2s;
    pointer-events: none;
  }
  .char-dialog.visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  .dialog-arrow { color: var(--amber); flex-shrink: 0; }
  .dialog-cursor-blink {
    display: inline-block;
    width: 0.5em;
    height: 0.9em;
    background: var(--amber-bright);
    vertical-align: middle;
    animation: cursorBlink 1s step-end infinite;
  }
  @keyframes cursorBlink { 0%,100%{opacity:1} 50%{opacity:0} }

  /* ── Title card ────────────────────────── */
  .hero-right { flex: 1; min-width: 0; }

  .title-card {
    font-family: var(--font-pixel);
    text-align: center;
    margin-bottom: 2rem;
    line-height: 1.4;
  }
  .tc-top, .tc-bot { color: var(--amber-dim); font-size: 1.1rem; }
  .tc-name {
    font-size: clamp(1.6rem, 4vw, 3rem);
    color: var(--amber-bright);
    text-shadow: var(--glow-strong);
    letter-spacing: 0.12em;
    padding: 0.1em 0;
  }
  .tc-role {
    font-size: 0.95rem;
    color: var(--teal);
    letter-spacing: 0.18em;
    text-shadow: 0 0 8px rgba(42, 154, 136, 0.4);
    margin-bottom: 0.2em;
  }

  .boot-terminal {
    font-family: var(--font-mono);
    font-size: 0.88rem;
    color: var(--text);
    white-space: pre-line;
    min-height: 9em;
    border-left: 2px solid var(--border-bright);
    padding-left: 1rem;
    line-height: 1.85;
  }

  /* ── Nav cards ─────────────────────────── */
  .link-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
  }
  .quick-link {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 1rem;
    border: 1px solid var(--border);
    background: var(--bg);
    transition: border-color 0.2s, background 0.2s;
    text-decoration: none;
  }
  .quick-link:hover {
    border-color: var(--amber);
    background: var(--bg-3);
    text-decoration: none;
    box-shadow: inset 0 0 14px rgba(200, 144, 42, 0.06);
  }
  .ql-icon  { font-family: var(--font-pixel); font-size: 1.1rem; color: var(--teal); }
  .ql-label { font-family: var(--font-pixel); font-size: 1.05rem; color: var(--amber-bright); letter-spacing: 0.06em; }
  .ql-sub   { font-size: 0.8rem; color: var(--text-dim); }

  /* ── Recent posts ──────────────────────── */
  .post-list { list-style: none; padding: 0; margin: 0; }
  .post-item { padding: 0.4rem 0; border-bottom: 1px solid var(--bg-3); display: flex; flex-wrap: wrap; align-items: baseline; gap: 0.4rem; }
  .post-date { font-size: 0.85rem; }
  .post-sep  { font-family: var(--font-pixel); }
</style>
