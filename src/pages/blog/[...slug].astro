---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }: CollectionEntry<'blog'>) => !data.draft);
  return posts.map((post: CollectionEntry<'blog'>) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props { post: CollectionEntry<'blog'>; }
const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article>
    <header class="post-header">
      <p><a href="/blog">&lt; back to field notes</a></p>
      <h1 class="post-title glitch">{post.data.title}</h1>
      <div class="post-meta">
        <time class="dim" datetime={post.data.date.toISOString()}>
          {post.data.date.toISOString().slice(0, 10)}
        </time>
        {post.data.tags.length > 0 && (
          <span class="tags">
            {post.data.tags.map((t: string) => <span class="tag">{t}</span>)}
          </span>
        )}
      </div>
    </header>

    <div class="prose">
      <Content />
    </div>

    <footer class="post-footer">
      <a href="/blog">&lt; back to field notes</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .post-header { margin-bottom: 2rem; }
  .post-title  { font-size: 2rem; margin: 0.75rem 0 0.5rem; line-height: 1.2; }
  .post-meta   { display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; font-size: 0.85rem; }
  .post-footer { margin-top: 3rem; padding-top: 1rem; border-top: 1px solid var(--border); }

  /* ── Prose styles ─── */
  .prose { color: var(--white); max-width: 720px; }
  .prose :global(h2) { font-size: 1.5rem; margin: 2rem 0 0.75rem; border-bottom: 1px solid var(--border); padding-bottom: 0.25rem; }
  .prose :global(h3) { font-size: 1.2rem; margin: 1.5rem 0 0.5rem; color: var(--amber); }
  .prose :global(p)  { margin-bottom: 1rem; line-height: 1.75; }
  .prose :global(ul), .prose :global(ol) { margin: 0 0 1rem 1.5rem; }
  .prose :global(li) { margin-bottom: 0.35rem; }
  .prose :global(a)  { color: var(--green-bright); }
  .prose :global(strong) { color: var(--green-bright); }
  .prose :global(em) { color: var(--amber); font-style: normal; }

  .prose :global(code) {
    font-family: var(--font-mono);
    background: var(--bg-3);
    border: 1px solid var(--border);
    padding: 0.1em 0.35em;
    font-size: 0.88em;
    color: var(--green-bright);
  }

  .prose :global(pre) {
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-left: 3px solid var(--green-dim);
    padding: 1rem 1.25rem;
    overflow-x: auto;
    margin: 1rem 0 1.5rem;
    font-size: 0.87em;
  }
  .prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    color: var(--green);
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--amber);
    padding-left: 1rem;
    color: var(--green-dim);
    margin: 1rem 0;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }
  .prose :global(th) { border: 1px solid var(--border); padding: 0.4rem 0.75rem; color: var(--amber); font-family: var(--font-heading); background: var(--bg-3); text-align: left; }
  .prose :global(td) { border: 1px solid var(--border); padding: 0.4rem 0.75rem; }
</style>
