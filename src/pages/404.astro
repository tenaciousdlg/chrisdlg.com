---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404" description="Page not found.">
  <div style="text-align:center; padding: 4rem 0;">
    <div style="font-family:var(--font-pixel); font-size:6rem; color:var(--amber-bright); text-shadow:var(--glow-strong); line-height:1;">
      404
    </div>
    <p style="font-family:var(--font-pixel); font-size:1.4rem; color:var(--teal); letter-spacing:0.1em; margin:1rem 0;">
      LOCATION NOT FOUND
    </p>
    <p class="dim" style="margin-bottom:2rem;">
      This area of the map hasn't been explored yet.
    </p>
    <a href="/" style="font-family:var(--font-pixel); font-size:1.1rem;">&lt; RETURN TO BASE CAMP</a>
  </div>
</BaseLayout>
